# Copy this file to .env and fill in real values. Do NOT commit .env.

# Demo mode. When true, the app runs entirely on a seeded synthetic profile:
# no real Oura, calendar, weather, cycle, or saved-brief data is read or written,
# and the clinic view shows synthetic patients only (no real user). Anything
# truthy works: true/1/yes/on. Leave unset (or false) for normal operation.
DEMO_MODE=false

# Oura Ring personal access token (https://cloud.ouraring.com/personal-access-tokens)
# Not required when DEMO_MODE=true.
OURA_TOKEN=your-oura-personal-access-token

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ElevenLabs (text-to-speech for the spoken morning brief)
# API key needs the text_to_speech permission (voices_read to list voices).
# Find voice IDs via GET https://api.elevenlabs.io/v1/voices
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
# Optional. Defaults to eleven_multilingual_v2 if unset.
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- Google Calendar (optional) ---
# Not read from env. The OAuth client secret and tokens are file-based:
#   credentials.json  — downloaded OAuth client secret (rename your
#                       client_secret_*.apps.googleusercontent.com.json to this)
#   token.json        — generated on first auth via `python test_oauth.py`
# Both are gitignored. Keep them out of version control.
