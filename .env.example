# Copy this file to .env and fill in real values. Do NOT commit .env.

# Oura Ring personal access token (https://cloud.ouraring.com/personal-access-tokens)
OURA_TOKEN=your-oura-personal-access-token

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id

# --- Google Calendar (optional) ---
# Not read from env. The OAuth client secret and tokens are file-based:
#   credentials.json  — downloaded OAuth client secret (rename your
#                       client_secret_*.apps.googleusercontent.com.json to this)
#   token.json        — generated on first auth via `python test_oauth.py`
# Both are gitignored. Keep them out of version control.
